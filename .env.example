# Mining Intelligence Agent - Environment Variables
# Copy this file to .env and fill in your keys

# Required: Anthropic API key for the Agent client
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Optional: NewsAPI key (not required; sample data used as fallback)
NEWSAPI_KEY=

# Optional: Enable live data mode (adds noise to sample prices for demo realism)
LIVE_MODE=false
